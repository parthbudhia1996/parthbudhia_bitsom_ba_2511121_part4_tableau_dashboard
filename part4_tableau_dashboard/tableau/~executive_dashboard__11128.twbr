      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0764727189516288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0764727190155265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0764727190212610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0764727190917123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0764727191113732]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;0-2 Days (Fast)&quot;&#13;&#10;    ELSEIF [delivery_days] &lt;= 5 THEN &quot;3-5 Days (Standard)&quot;&#13;&#10;    ELSE &quot;6+ Days (Delayed)&quot;&#13;&#10;    END' />
      </column>
      <column caption='dashboard_sales_data' datatype='table' name='[__tableau_internal_object_id__].[dashboard!sales!data_546E97FE89BF400CB384984CFD3A9C44]' role='measure' type='quantitative' />
